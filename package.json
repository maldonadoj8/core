{
  "name": "@silasdevs/core",
  "version": "0.2.0",
  "description": "Normalized, reactive data cache for multi-entity REST APIs with schema-driven classification and property-level React bindings.",
  "type": "module",
  "sideEffects": [
    "./dist/compat/index.js"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./compat": {
      "import": "./dist/compat/index.js",
      "types": "./dist/compat/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^24.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "reactive",
    "proxy",
    "state-management",
    "react",
    "hooks",
    "store",
    "observable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maldonadoj8/core.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@types/node": "$@types/node",
    "picomatch": "^4.0.4"
  }
}
